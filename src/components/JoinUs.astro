---
import { siteContent } from "@/Data/content";

const { joinUs } = siteContent;
---

<section id="join-us">
  <div class="content">
    <h2>{joinUs.title}</h2>
    <p>
      {joinUs.description}
    </p>
    <button class="btn-join-us" onclick="window.location.href='#contact'">
      {joinUs.buttonText}
    </button>
  </div>
</section>

<style>
  button {
    font-weight: 500;
    border: 1px solid var(--stroke-color);
    color: var(--primary-text-color);
    background-color: transparent;
    border-radius: 8px;
    padding: 12px 24px;
    transition: background-color 0.3s ease;
  }
  section {
    background-image: url("/assets/images/astronauta.webp");
    background-position: left center;
    background-repeat: no-repeat;
    width: 100%;
    height: 624px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding-right: 15%;
    margin: 64px 0;
  }

  .content {
    max-width: 450px;
    text-align: left;
  }

  .btn-join-us {
    background-color: #c8342d;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 16px;
  }

  button:hover {
    background-color: #b72a2a;
  }
</style>
