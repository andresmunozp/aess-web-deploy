---
import NotificationBanner from "./NotificationBanner.astro";
import { siteContent } from "@/Data/content";

const { contact } = siteContent;

// Componente de formulario de contacto reutilizable
export interface Props {
  formspreeEndpoint: string;
  className?: string;
}

const { formspreeEndpoint, className = "" } = Astro.props;
---

<NotificationBanner
  type="success"
  emoji={contact.form.notification.success.emoji}
  title={contact.form.notification.success.title}
  message={contact.form.notification.success.message}
  autoHide={true}
  duration={5000}
/>

<div class={`contact-form-wrapper ${className}`}>
  <img src="/assets/images/bh.webp" alt="Agujero negro" loading="lazy" />
  <form id="contact-form" action={formspreeEndpoint} method="POST">
    <div class="form-row">
      <div class="form-field">
        <label for="name">{contact.form.labels.name}</label>
        <input type="text" id="name" name="name" required />
      </div>

      <div class="form-field">
        <label for="email">{contact.form.labels.email}</label>
        <input type="email" id="email" name="email" required />
      </div>
    </div>

    <div class="form-field">
      <label for="message">{contact.form.labels.message}</label>
      <textarea id="message" name="message" rows="4" required></textarea>
    </div>

    <button type="submit" id="submit-btn">
      <span id="btn-text">{contact.form.submitButton}</span>
      <span id="btn-loading" class="loading-spinner hidden">
        <span class="spinner"></span>
        {contact.form.submitButtonLoading}
      </span>
    </button>
  </form>
</div>

<style>

  button {
    font-weight: 500;
    border: 1px solid var(--stroke-color);
    color: var(--primary-text-color);
    background-color: transparent;
    border-radius: 8px;
    padding: 12px 24px;
    transition: background-color 0.3s ease;
}
  .contact-form-wrapper {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(16px, 4vw, 32px);
    padding: 16px 0 16px 0;
    align-items: start;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: clamp(12px, 2vw, 16px);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  label {
    margin-bottom: 8px;
    font-weight: 500;
    color: var(--primary-text-color);
  }

  input,
  textarea {
    background-color: var(--background-color);
    border: none;
    border-bottom: 2px solid var(--stroke-color);
    color: var(--primary-text-color);
    padding: 12px 0 12px 6px;
    outline: none;
    transition: border-bottom-color 0.3s ease;
  }

  input:focus,
  textarea:focus {
    border-bottom-color: #ff4444;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--stroke-color);
  }

  textarea {
    resize: none;
    field-sizing: content;
    min-height: 100px;
    max-height: 280px;
    overflow-y: auto;
  }

  button {
    background-color: #c8342d;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 16px;
    align-self: flex-start;
  }

  button:hover {
    background-color: #b72a2a;
  }

  input:-webkit-autofill,
  textarea:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 30px #313030 inset;
    -webkit-text-fill-color: var(--primary-text-color);
    background-color: var(--background-color);
    border-bottom: 2px solid #c8342d;
  }

  /* Loading spinner */
  .loading-spinner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top: 2px solid #ffffff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  #submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    background-color: #666;
  }

  #submit-btn:disabled:hover {
    background-color: #666;
  }

  /* Estado inicial - loading oculto por defecto */
  .hidden {
    display: none !important;
  }

  /* Animaciones */
  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    .contact-form-wrapper {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }
</style>

<script>
  import { $ } from "@/utils/dom-selector";

  // Extender la interfaz Window para incluir notificationBanner
  declare global {
    interface Window {
      notificationBanner?: {
        updateContent: (props: {
          type: "success" | "error" | "info" | "warning";
          emoji: string;
          title: string;
          message: string;
        }) => void;
        show: (autoHide?: boolean) => void;
        hide: () => void;
      };
    }
  }

  document.addEventListener("DOMContentLoaded", function (): void {
    const $form = $<HTMLFormElement>("#contact-form")!;
    const $submitBtn = $<HTMLButtonElement>("#submit-btn")!;
    const $btnText = $<HTMLSpanElement>("#btn-text")!;
    const $btnLoading = $<HTMLSpanElement>("#btn-loading")!;

    function setLoadingState(loading: boolean): void {
      $submitBtn.disabled = loading;

      if (loading) {
        $btnText.classList.add("hidden");
        $btnLoading.classList.remove("hidden");
      } else {
        $btnText.classList.remove("hidden");
        $btnLoading.classList.add("hidden");
      }
    }

    function clearForm(): void {
      $form.reset();
    }

    $form.addEventListener(
      "submit",
      async function (e: SubmitEvent): Promise<void> {
        e.preventDefault();

        setLoadingState(true);

        try {
          const formData = new FormData($form);

          const response: Response = await fetch($form.action, {
            method: "POST",
            body: formData,
            headers: {
              Accept: "application/json",
            },
          });

          if (response.ok) {
            setLoadingState(false);

            // Usar la API del NotificationBanner
            if (typeof window.notificationBanner !== "undefined") {
              window.notificationBanner.updateContent({
                type: "success",
                emoji: "🚀",
                title: "¡Mensaje enviado al espacio!",
                message:
                  "Tu mensaje ha sido lanzado exitosamente. Nuestro equipo de astronautas lo revisará pronto.",
              });
              window.notificationBanner.show(true); // Auto-hide después de 5 segundos
            }

            clearForm();
          } else {
            setLoadingState(false);
            throw new Error("Network response was not ok");
          }
        } catch (error) {
          console.error("Error:", error);
          setLoadingState(false);

          // Usar la API del NotificationBanner para errores
          if (typeof window.notificationBanner !== "undefined") {
            window.notificationBanner.updateContent({
              type: "error",
              emoji: "🛸",
              title: "Houston, tenemos un problema...",
              message:
                "No pudimos enviar tu mensaje en este momento. Por favor, inténtalo de nuevo.",
            });
            window.notificationBanner.show(false); // No auto-hide para errores
          }
        }
      }
    );
  });
</script>
