---
import Arrow from "./Arrow.astro";

interface Props {
  imageSrc: string;
  imageAlt: string;
  division: string;
}

const { imageSrc, imageAlt, division } = Astro.props;
---

<button>
  <img src={imageSrc} alt={imageAlt} loading="lazy"/>
  <div class="card-content">
    <p>{division}</p>
    <Arrow />
  </div>
</button>

<style>
  button {
    position: relative;
    display: block;
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    transition: transform 0.2s ease-in-out;
    overflow: hidden;
    border-radius: 4px;
    min-height: 300px;
  }

  button:hover p {
    filter: brightness(1.3) drop-shadow(0 0 12px rgba(255, 255, 255, 0.4));
  }

  button img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
  }

  button::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      transparent 100%
    );

    pointer-events: none;
  }

  .card-content {
    display: flex;
    width: 90%;
    align-items: center;
    justify-content: space-between;
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .card-content p {
    max-width: 10ch;
    text-align: left;
  }

  .card-content :global(svg) {
    transition: transform 0.3s ease;
  }

  button:hover .card-content :global(svg) {
    transform: translateX(4px);
  }
</style>
